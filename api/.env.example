# Import Desk API. Phase A runs the frontend on seed data — this API is only
# needed for the AI document-extraction features.
PORT=8787
CORS_ORIGIN=http://localhost:5173

# ── AI (combined providers) ────────────────────────────────────────────
# Gemini handles vision (PDF + photo extraction, discrepancy). Get a free key:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# DeepSeek handles cheap text (translate). https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# text-task provider: auto | gemini | deepseek
AI_TEXT_PROVIDER=auto

# ── Reminders (n8n) ────────────────────────────────────────────────────
# POST target for shipment ETD/ETA reminders. The n8n flow sends the email/
# WhatsApp. Leave blank to disable (the app degrades gracefully). See
# docs/n8n-reminders.md for the production daily-cron flow.
N8N_REMINDER_WEBHOOK=
REMINDER_AMBER_DAYS=3
# Used in the reminder payload so the email can deep-link back to the app.
APP_URL=http://localhost:5173

# ── Shared data (Phase B — Postgres) ───────────────────────────────────
# Unset => API runs open + data-less (app falls back to per-browser IndexedDB).
# Set => shared data: one JSONB row per import file, auto-created on boot.
# Coolify: use the internal connection string of your Postgres resource.
DATABASE_URL=
# DATABASE_SSL=1 only for an external TLS Postgres (Coolify-internal is plain).
DATABASE_SSL=

# ── File storage ───────────────────────────────────────────────────────
# Uploaded documents are written here (a persistent volume in prod) instead of
# being inlined into the database. Bytes are streamed back via /files/blob/:key.
UPLOADS_DIR=/data/uploads

# ── Shared-password auth (Phase B) ─────────────────────────────────────
# Unset => no login (open). Set => the whole app requires this one password.
APP_PASSWORD=
# Optional: extra secret to derive the bearer token. Defaults to APP_PASSWORD.
APP_SECRET=

# ── Legacy MySQL knobs (unused — superseded by DATABASE_URL) ────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=import_desk
MYSQL_PASSWORD=
MYSQL_DATABASE=import_desk

# ── Storage (later) ────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
