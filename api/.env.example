# Import Desk API. Phase A runs the frontend on seed data — this API is only
# needed for the AI document-extraction features.
PORT=8787
CORS_ORIGIN=http://localhost:5173

# ── AI (combined providers) ────────────────────────────────────────────
# Gemini handles vision (PDF + photo extraction, discrepancy). Get a free key:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# DeepSeek handles cheap text (translate). https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# text-task provider: auto | gemini | deepseek
AI_TEXT_PROVIDER=auto

# ── MySQL (Phase B) ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=import_desk
MYSQL_PASSWORD=
MYSQL_DATABASE=import_desk

# ── Auth / storage (Phase B) ───────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
JWT_SECRET=
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
