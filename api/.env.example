# Import Desk API (Phase B). Phase A runs the frontend on seed data — this API is
# not required to demo the app.
PORT=8080
CORS_ORIGIN=http://localhost:5173

# MySQL (Phase B)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=import_desk
MYSQL_PASSWORD=
MYSQL_DATABASE=import_desk

# Auth (Phase B)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
JWT_SECRET=

# Storage (Phase B) — local disk or S3-compatible
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
