# Import Desk — Docker Compose env. Copy to `.env` for local runs; on Coolify set
# these in the resource's Environment Variables. NEVER commit real keys.

# ── Web ────────────────────────────────────────────────────────────────
# Same-origin: leave as /api. nginx in the web container proxies /api -> api:8787,
# so no domain is baked into the build and there's no CORS.
VITE_API_URL=/api
WEB_PORT=8080

# ── Shared data (Postgres) ─────────────────────────────────────────────
# Blank => each browser keeps its own data (IndexedDB). Set => shared across the
# team (one JSONB row per import file, table auto-created on boot).
# Coolify: paste the INTERNAL connection string of your Postgres resource, e.g.
#   postgres://postgres:<password>@<internal-host>:5432/postgres
DATABASE_URL=
# DATABASE_SSL=1 only for an external TLS Postgres (Coolify-internal is plain).
DATABASE_SSL=

# ── Shared-password auth ───────────────────────────────────────────────
# Blank => no login (open). Set => the whole app requires this one password.
APP_PASSWORD=
# Optional extra secret to derive the bearer token; defaults to APP_PASSWORD.
APP_SECRET=

# ── API misc ───────────────────────────────────────────────────────────
# Same-origin => CORS irrelevant; keep * (only matters for direct api access).
CORS_ORIGIN=*
# Used in reminder emails to deep-link back to the app. Prod: https://<web-domain>.
APP_URL=

# ── AI providers (server-side only — never reach the browser) ──────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
AI_TEXT_PROVIDER=auto

# Optional n8n reminder webhook.
N8N_REMINDER_WEBHOOK=
