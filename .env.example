# Import Desk — Docker Compose env. Copy to `.env` for local runs; on Coolify
# set these in the resource's Environment Variables. NEVER commit real keys.

# ── Web (baked into the SPA at build time) ─────────────────────────────
# Public URL of the API. Local: http://localhost:8787. Prod: https://api.<domain>.
VITE_API_URL=http://localhost:8787
WEB_PORT=8080

# ── API ────────────────────────────────────────────────────────────────
API_PORT=8787
# Allowed browser origin. Local: http://localhost:8080. Prod: the web domain.
CORS_ORIGIN=http://localhost:8080
APP_URL=http://localhost:8080

# AI providers (server-side only — never reach the browser).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
AI_TEXT_PROVIDER=auto

# Optional n8n reminder webhook.
N8N_REMINDER_WEBHOOK=

# ── MySQL (Phase B only — needed for `--profile full`) ─────────────────
MYSQL_DATABASE=import_desk
MYSQL_USER=import_desk
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
